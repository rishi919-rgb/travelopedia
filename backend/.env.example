# ==================================
# Travelopedia – Backend .env.example
# ==================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# Server
PORT=5000

# MongoDB Connection String (from MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/travelopedia?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_long_random_secret_key_here
JWT_EXPIRES_IN=30d

# Google Gemini AI API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...your_key_here

# (Optional) Frontend URL for CORS in production
CLIENT_URL=http://localhost:5173
